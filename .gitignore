# Specific files and directories to be ignored in the github commit process

# Tarballs of docker images
*.tar
*.tar.gz
*.img
*.img.zip

# Python cache / temp files
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# OS / editor junk
.DS_Store
*.swp
*.swo

# Data directories / test files
data/
*.log
shared/myhelpers_jauger/*.tfm
shared/myhelpers_jauger/*.nii*
shared/myhelpers_jauger/*.nrrd
shared/myhelpers_jauger/*.csv